{
  "version": 2,
  "builds": [
    {
      "src": "advogado_trabalhista.py",
      "use": "@vercel/python"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/api/(.*)",
      "dest": "/advogado_trabalhista.py"
    }
  ],
  "env": {
    "PYTHONPATH": ".",
    "SUPABASE_URL": "@supabase_url",
    "SUPABASE_KEY": "@supabase_key",
    "OPENAI_API_KEY": "@openai_api_key"
  },
  "functions": {
    "advogado_trabalhista.py": {
      "runtime": "python3.9"
    }
  }
}