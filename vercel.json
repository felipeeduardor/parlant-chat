{
  "version": 2,
  "installCommand": "pip install -r requirements.txt",
  "builds": [
    {
      "src": "advogado_trabalhista.py",
      "use": "@vercel/python"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/api/(.*)",
      "dest": "/advogado_trabalhista.py"
    }
  ]
}